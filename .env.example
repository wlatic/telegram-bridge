# Telegram Bridge Configuration
# Copy this to ~/.config/telegram-bridge/.env and fill in values

# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Create a Forum-enabled group, add bot as admin, send a message, then check bot updates
TELEGRAM_GROUP_ID=

# Get from @userinfobot on Telegram
TELEGRAM_ALLOWED_USER=

# Enable /kill command (default: disabled)
ENABLE_KILL=false

# Optional: for voice message transcription (try Groq first — it's free)
# GROQ_API_KEY=
# OPENAI_API_KEY=
