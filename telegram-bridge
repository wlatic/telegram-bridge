cmd_status() {
    local topic_id="$1"
    log "Command: /status"

    # Helper: format session status line
    _session_status_line() {
        local sess="$1"
        local working_file="${CONFIG_DIR}/working_${sess}"
        local activity_file="${CONFIG_DIR}/activity_${sess}"
        local agent_status_file="${CONFIG_DIR}/agent_status_${sess}"
        local status=""

        if [[ -f "$working_file" ]]; then
            status="Working..."
            if [[ -f "$agent_status_file" ]]; then
                local agent_info
                agent_info=$(cat "$agent_status_file" 2>/dev/null) || true
                # Extract agent name from status like "Working.... (@foo)"
                if [[ "$agent_info" =~ \(@([a-zA-Z0-9_-]+)\) ]]; then
                    status="Working... (@${BASH_REMATCH[1]})"
                fi
            fi
        elif [[ -f "$activity_file" ]]; then
            local last_act now_s ago
            last_act=$(cat "$activity_file" 2>/dev/null) || last_act=0
            now_s=$(date +%s)
            ago=$(( now_s - last_act ))
            if (( ago < 60 )); then
                status="Idle (${ago}s ago)"
            elif (( ago < 3600 )); then
                status="Idle ($(( ago / 60 ))m ago)"
            else
                status="Idle ($(( ago / 3600 ))h ago)"
            fi
        else
            status="Idle"
        fi
        echo "$status"
    }

    # If used in a session topic, show that session's status
    if (( topic_id > 0 )); then
        local session_name
        session_name=$(get_session_for_topic "$topic_id")
        if [[ -n "$session_name" ]]; then
            if ! tmux has-session -t "$session_name" 2>/dev/null; then
                send_message "$topic_id" "<i>Session ended.</i>"
                mark_topic_inactive "$session_name"
                return
            fi

            local status
            status=$(_session_status_line "$session_name")
            local escaped_status
            escaped_status=$(escape_html "$status")

            # Get uptime
            local created_ts uptime_str=""
            created_ts=$(tmux list-sessions -F '#{session_name} #{session_created}' 2>/dev/null \
                | awk -v s="$session_name" '$1 == s {print $2}') || true
            if [[ -n "$created_ts" ]]; then
                local now_s=$( date +%s )
                local up=$(( now_s - created_ts ))
                local hours=$(( up / 3600 ))
                local mins=$(( (up % 3600) / 60 ))
                uptime_str="${hours}h ${mins}m"
            fi

            local escaped_sess
            escaped_sess=$(escape_html "$session_name")
            local msg="<b>Session:</b> ${escaped_sess}
<b>Status:</b> ${escaped_status}
<b>Uptime:</b> ${uptime_str:-unknown}"
            send_message "$topic_id" "$msg"
            return
        fi
    fi

    # General or unmapped topic: show ALL active sessions
    local output=""
    local count=0

    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        local name
        name=$(echo "$line" | cut -d'|' -f1)
        local status
        status=$(_session_status_line "$name")
        local escaped_name escaped_status
        escaped_name=$(escape_html "$name")
        escaped_status=$(escape_html "$status")
        output+="<code>${escaped_name}</code> — ${escaped_status}\n"
        (( count++ )) || true
    done < <(get_claude_sessions)

    if (( count == 0 )); then
        output="<i>No active sessions</i>"
    fi

    if (( topic_id > 0 )); then
        send_message "$topic_id" "$output"
    else
        send_general_message "$output"
    fi
}

