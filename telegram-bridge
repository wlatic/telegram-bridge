#!/bin/bash
# telegram-bridge — Bridges Telegram Forum Topics to tmux Claude Code sessions
# Runs as a background tmux session, polling Telegram for messages and routing
# them to/from Claude Code sessions via tmux send-keys + capture-pane.
#
# Usage: telegram-bridge          (launches in background tmux session)
#        telegram-bridge --loop   (runs the main loop directly — used internally)
#
# Config: ~/.config/telegram-bridge/.env
# State:  ~/.config/telegram-bridge/state.json

set -uo pipefail
# Note: NOT using set -e — the main loop must be resilient to individual
# command failures (API errors, jq parse failures, missing sessions, etc.)

# ── Config ────────────────────────────────────────────────────────────

CONFIG_DIR="${HOME}/.config/telegram-bridge"
ENV_FILE="${CONFIG_DIR}/.env"
STATE_FILE="${CONFIG_DIR}/state.json"
LOG_DIR="/mnt/zfs/claude/system/logs"
LOG_FILE="${LOG_DIR}/telegram-bridge.log"
PROJECT_DIR="/mnt/zfs/claude/system"

SKIP_SESSIONS="janitor|telegram-bridge|monitor|dev|admin|brain"
POLL_INTERVAL=2
SESSION_CHECK_INTERVAL=10

# Topic icon colors
COLOR_GREEN=9367192    # normal sessions
COLOR_RED=16478047     # danger sessions
COLOR_BLUE=7322096     # resumed sessions

# ── Self-launch pattern (same as janitor) ─────────────────────────────

if [[ "${1:-}" == "--loop" ]]; then
    :
else
    if tmux has-session -t telegram-bridge 2>/dev/null; then
        echo "Telegram bridge already running"
        exit 0
    fi
    tmux new-session -d -s telegram-bridge "$(readlink -f "$0") --loop"
    echo "Telegram bridge session started"
    exit 0
fi

# ── Load config ───────────────────────────────────────────────────────

if [[ ! -f "$ENV_FILE" ]]; then
    echo "Error: Config file not found at $ENV_FILE"
    echo "Create it with TELEGRAM_BOT_TOKEN, TELEGRAM_GROUP_ID, TELEGRAM_ALLOWED_USER"
    exit 1
fi

# shellcheck source=/dev/null
source "$ENV_FILE"

BOT_TOKEN="${TELEGRAM_BOT_TOKEN:?Missing TELEGRAM_BOT_TOKEN in .env}"
GROUP_ID="${TELEGRAM_GROUP_ID:?Missing TELEGRAM_GROUP_ID in .env}"
ALLOWED_USER="${TELEGRAM_ALLOWED_USER:?Missing TELEGRAM_ALLOWED_USER in .env}"
ENABLE_KILL="${ENABLE_KILL:-false}"
GROQ_API_KEY="${GROQ_API_KEY:-}"
OPENAI_API_KEY="${OPENAI_API_KEY:-}"

API="https://api.telegram.org/bot${BOT_TOKEN}"
TMP_DIR="/home/claude/tmp"

OFFSETS_DIR="${CONFIG_DIR}/offsets"
WATCHERS_DIR="${CONFIG_DIR}/watchers"
LAST_SENT_DIR="${CONFIG_DIR}/last_sent"

mkdir -p "$LOG_DIR" "$CONFIG_DIR" "$OFFSETS_DIR" "$WATCHERS_DIR" "$LAST_SENT_DIR" "$TMP_DIR"

# ── Logging ───────────────────────────────────────────────────────────

log() {
    local msg="[$(date '+%Y-%m-%d %H:%M:%S')] $*"
    echo "$msg"
    echo "$msg" >> "$LOG_FILE" 2>/dev/null || true
}

# ── State management ──────────────────────────────────────────────────

init_state() {
    if [[ ! -f "$STATE_FILE" ]]; then
        echo '{"offset":0,"topics":{}}' > "$STATE_FILE"
    fi
}

get_state() {
    local key="$1"
    jq -r "$key" "$STATE_FILE" 2>/dev/null || echo ""
}

set_state() {
    local key="$1" value="$2"
    local tmp="${STATE_FILE}.tmp"
    jq "$key = $value" "$STATE_FILE" > "$tmp" && mv "$tmp" "$STATE_FILE"
}

get_offset() {
    local off
    off=$(get_state '.offset')
    echo "${off:-0}"
}

set_offset() {
    set_state '.offset' "$1"
}

# Map a session name to a topic ID
set_topic_mapping() {
    local session="$1" topic_id="$2" pane_pid="${3:-0}" conv_id="${4:-}"
    local now
    now=$(date -u '+%Y-%m-%dT%H:%M:%S')
    local tmp="${STATE_FILE}.tmp"
    jq --arg s "$session" --argjson t "$topic_id" --arg c "$now" --arg pid "$pane_pid" --arg cid "$conv_id" \
        '.topics[$s] = {"topic_id": $t, "created": $c, "active": true, "pane_pid": $pid, "conv_id": $cid}' \
        "$STATE_FILE" > "$tmp" && mv "$tmp" "$STATE_FILE"
}

# Find an inactive topic by conversation ID (for reopening)
find_inactive_topic_by_conv() {
    local conv_id="$1"
    [[ -z "$conv_id" ]] && return
    jq -r --arg cid "$conv_id" \
        '.topics | to_entries[] | select(.value.active == false and .value.conv_id == $cid) | "\(.key)|\(.value.topic_id)"' \
        "$STATE_FILE" 2>/dev/null | head -1
}

# Reopen a closed topic
reopen_topic() {
    local topic_id="$1"
    local payload
    payload=$(jq -n --argjson chat "$GROUP_ID" --argjson topic "$topic_id" \
        '{chat_id: $chat, message_thread_id: $topic}')
    tg_api "reopenForumTopic" -d "$payload"
}

# Reactivate a topic mapping under a (possibly new) session name
reactivate_topic_mapping() {
    local old_name="$1" new_name="$2" pane_pid="${3:-0}"
    local tmp="${STATE_FILE}.tmp"
    if [[ "$old_name" == "$new_name" ]]; then
        jq --arg s "$new_name" --arg pid "$pane_pid" \
            '.topics[$s].active = true | .topics[$s].pane_pid = $pid' \
            "$STATE_FILE" > "$tmp" && mv "$tmp" "$STATE_FILE"
    else
        jq --arg old "$old_name" --arg new "$new_name" --arg pid "$pane_pid" \
            '.topics[$new] = .topics[$old] | .topics[$new].active = true | .topics[$new].pane_pid = $pid | del(.topics[$old])' \
            "$STATE_FILE" > "$tmp" && mv "$tmp" "$STATE_FILE"
    fi
}

# Get session name for a topic ID
get_session_for_topic() {
    local topic_id="$1"
    jq -r --argjson t "$topic_id" \
        '.topics | to_entries[] | select(.value.topic_id == $t and .value.active == true) | .key' \
        "$STATE_FILE" 2>/dev/null | head -1
}

# Get topic ID for a session name (active only)
get_topic_for_session() {
    local session="$1"
    jq -r --arg s "$session" 'if .topics[$s].active == true then .topics[$s].topic_id else empty end' "$STATE_FILE" 2>/dev/null
}

# Mark a topic as inactive
mark_topic_inactive() {
    local session="$1"
    local tmp="${STATE_FILE}.tmp"
    jq --arg s "$session" '.topics[$s].active = false' "$STATE_FILE" > "$tmp" && mv "$tmp" "$STATE_FILE"
}

# Update session name in state (for renames)
rename_topic_mapping() {
    local old_name="$1" new_name="$2"
    local tmp="${STATE_FILE}.tmp"
    jq --arg old "$old_name" --arg new "$new_name" \
        '.topics[$new] = .topics[$old] | del(.topics[$old])' \
        "$STATE_FILE" > "$tmp" && mv "$tmp" "$STATE_FILE"
}

# ── HTML escaping ─────────────────────────────────────────────────────

escape_html() {
    local text="$1"
    printf '%s' "$text" | sed 's/&/\&amp;/g; s/</\&lt;/g; s/>/\&gt;/g'
}

# ── Telegram API helpers ──────────────────────────────────────────────

tg_api() {
    local method="$1"
    shift
    local response
    response=$(curl -s -X POST -H "Content-Type: application/json" "$@" "${API}/${method}")

    # Handle rate limiting
    local ok
    ok=$(echo "$response" | jq -r '.ok' 2>/dev/null) || true
    if [[ "$ok" == "false" ]]; then
        local error_code
        error_code=$(echo "$response" | jq -r '.error_code' 2>/dev/null) || true
        if [[ "$error_code" == "429" ]]; then
            local retry_after
            retry_after=$(echo "$response" | jq -r '.parameters.retry_after // 5' 2>/dev/null) || true
            log "Rate limited, sleeping ${retry_after}s"
            sleep "$retry_after"
            response=$(curl -s -X POST -H "Content-Type: application/json" "$@" "${API}/${method}")
        else
            log "API error: $response"
        fi
    fi

    echo "$response"
}

send_message() {
    local topic_id="$1" text="$2" parse_mode="${3:-HTML}"
    local payload
    if [[ -n "$parse_mode" ]]; then
        payload=$(jq -n --argjson chat "$GROUP_ID" --argjson topic "$topic_id" \
            --arg text "$text" --arg mode "$parse_mode" \
            '{chat_id: $chat, message_thread_id: $topic, text: $text, parse_mode: $mode}')
    else
        payload=$(jq -n --argjson chat "$GROUP_ID" --argjson topic "$topic_id" \
            --arg text "$text" \
            '{chat_id: $chat, message_thread_id: $topic, text: $text}')
    fi
    tg_api "sendMessage" -d "$payload"
}

# Send message to general topic (topic_id not specified or 0)
send_general_message() {
    local text="$1" parse_mode="${2:-HTML}"
    local payload
    payload=$(jq -n --argjson chat "$GROUP_ID" \
        --arg text "$text" --arg mode "$parse_mode" \
        '{chat_id: $chat, text: $text, parse_mode: $mode}')
    tg_api "sendMessage" -d "$payload"
}

edit_message() {
    local message_id="$1" text="$2" parse_mode="${3:-HTML}"
    local payload
    payload=$(jq -n --argjson chat "$GROUP_ID" --argjson msg "$message_id" \
        --arg text "$text" --arg mode "$parse_mode" \
        '{chat_id: $chat, message_id: $msg, text: $text, parse_mode: $mode}')
    tg_api "editMessageText" -d "$payload"
}

create_topic() {
    local name="$1" color="${2:-$COLOR_GREEN}"
    local payload
    payload=$(jq -n --argjson chat "$GROUP_ID" --arg name "$name" --argjson color "$color" \
        '{chat_id: $chat, name: $name, icon_color: $color}')
    tg_api "createForumTopic" -d "$payload"
}

close_topic() {
    local topic_id="$1"
    local payload
    payload=$(jq -n --argjson chat "$GROUP_ID" --argjson topic "$topic_id" \
        '{chat_id: $chat, message_thread_id: $topic}')
    tg_api "closeForumTopic" -d "$payload"
}

delete_topic() {
    local topic_id="$1"
    local payload
    payload=$(jq -n --argjson chat "$GROUP_ID" --argjson topic "$topic_id" \
        '{chat_id: $chat, message_thread_id: $topic}')
    tg_api "deleteForumTopic" -d "$payload"
}

edit_topic_name() {
    local topic_id="$1" name="$2"
    local payload
    payload=$(jq -n --argjson chat "$GROUP_ID" --argjson topic "$topic_id" --arg name "$name" \
        '{chat_id: $chat, message_thread_id: $topic, name: $name}')
    tg_api "editForumTopic" -d "$payload"
}

# ── Session helpers (adapted from ai/janitor) ─────────────────────────

CONV_DIR="/home/claude/.claude/projects/-mnt-zfs-claude-system"

# Get conversation ID from a claude process
get_conv_id_for_session() {
    local sess="$1"
    local pane_pid
    pane_pid=$(tmux list-panes -t "$sess" -F '#{pane_pid}' 2>/dev/null | head -1) || true
    [[ -z "$pane_pid" ]] && return 0

    local claude_pid
    claude_pid=$(ps --ppid "$pane_pid" -o pid= 2>/dev/null | head -1 | tr -d ' ') || true
    [[ -z "$claude_pid" ]] && return 0

    # Try --resume in cmdline
    local cmdline
    cmdline=$(tr '\0' ' ' < "/proc/${claude_pid}/cmdline" 2>/dev/null) || true
    if [[ "$cmdline" =~ --resume[[:space:]]+([a-f0-9-]+) ]]; then
        local cid="${BASH_REMATCH[1]}"
        if [[ -f "${CONV_DIR}/${cid}.jsonl" ]]; then
            echo "$cid"
            return 0
        fi
    fi

    # Fallback: session file
    local sf="/home/claude/.claude/sessions/${claude_pid}.json"
    [[ -f "$sf" ]] || return 0
    local sid
    sid=$(python3 -c "import json; print(json.load(open('${sf}'))['sessionId'])" 2>/dev/null) || true
    if [[ -n "$sid" && -f "${CONV_DIR}/${sid}.jsonl" ]]; then
        echo "$sid"
    fi
}

is_skipped() {
    local name="$1"
    [[ "$name" =~ ^(${SKIP_SESSIONS})$ ]]
}

# Get active Claude sessions: name|pane_pid
get_claude_sessions() {
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        local name
        name=$(echo "$line" | awk '{print $1}')
        is_skipped "$name" && continue

        local cmd
        cmd=$(tmux list-panes -t "$name" -F '#{pane_current_command}' 2>/dev/null | head -1) || true

        if [[ "$cmd" == "claude" ]]; then
            local pane_pid
            pane_pid=$(tmux list-panes -t "$name" -F '#{pane_pid}' 2>/dev/null | head -1) || true
            echo "${name}|${pane_pid:-0}"
        fi
    done < <(tmux list-sessions -F '#{session_name} #{session_created}' 2>/dev/null || true)
}

# Auto-generate a session name
auto_session_name() {
    local base
    base="claude-$(date +%m%d)"
    local name="$base"
    local i=2
    while tmux has-session -t "$name" 2>/dev/null; do
        name="${base}-${i}"
        (( i++ )) || true
    done
    echo "$name"
}

# ── Command handlers ──────────────────────────────────────────────────

cmd_sessions() {
    local topic_id="$1"
    log "Command: /sessions"

    local output="<b>Active Claude Sessions</b>\n\n"
    local count=0

    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        local name
        name=$(echo "$line" | cut -d'|' -f1)
        local topic_mapped
        topic_mapped=$(get_topic_for_session "$name")
        local topic_info=""
        if [[ -n "$topic_mapped" ]]; then
            topic_info=" (topic #${topic_mapped})"
        fi
        output+="• <code>${name}</code>${topic_info}\n"
        (( count++ )) || true
    done < <(get_claude_sessions)

    if (( count == 0 )); then
        output+="<i>No active sessions</i>"
    else
        output+="\n${count} session(s) running"
    fi

    if (( topic_id > 0 )); then
        send_message "$topic_id" "$output"
    else
        send_general_message "$output"
    fi
}

cmd_new() {
    local topic_id="$1" mode="${2:-normal}"
    log "Command: /new $mode"

    local sname
    sname=$(auto_session_name)

    local claude_cmd="cd ${PROJECT_DIR} && claude"
    if [[ "$mode" == "danger" ]]; then
        claude_cmd="cd ${PROJECT_DIR} && claude --dangerously-skip-permissions"
    fi

    # Create tmux session
    tmux new-session -d -s "$sname" -c "$PROJECT_DIR"
    tmux send-keys -t "$sname" "$claude_cmd" Enter

    # Get pane PID for rename tracking
    local pane_pid
    pane_pid=$(tmux list-panes -t "$sname" -F '#{pane_pid}' 2>/dev/null | head -1) || true

    # Pick color based on mode
    local color="$COLOR_GREEN"
    [[ "$mode" == "danger" ]] && color="$COLOR_RED"

    # Create Telegram topic
    local response
    response=$(create_topic "$sname" "$color")
    local new_topic_id
    new_topic_id=$(echo "$response" | jq -r '.result.message_thread_id // empty') || true

    if [[ -n "$new_topic_id" ]]; then
        set_topic_mapping "$sname" "$new_topic_id" "${pane_pid:-0}"
        log "Created session '$sname' with topic $new_topic_id"

        # Notify in the requesting topic
        local notify_text="New session <code>${sname}</code> (${mode} mode) created with topic"
        if (( topic_id > 0 )); then
            send_message "$topic_id" "$notify_text"
        else
            send_general_message "$notify_text"
        fi

        # Welcome message in the new topic
        send_message "$new_topic_id" "Session <code>${sname}</code> is ready (${mode} mode). Messages here route to Claude."
    else
        log "Failed to create topic for session '$sname'"
        local err_text="Session <code>${sname}</code> created but topic creation failed. Check bot permissions."
        if (( topic_id > 0 )); then
            send_message "$topic_id" "$err_text"
        else
            send_general_message "$err_text"
        fi
    fi
}

cmd_resume() {
    local topic_id="$1"
    log "Command: /resume"

    # Get recent conversations
    local -a conv_ids=()
    local -a conv_summaries=()
    local -a conv_ages=()

    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        conv_ids+=("$(echo "$line" | cut -d'|' -f1)")
        conv_ages+=("$(echo "$line" | cut -d'|' -f2)")
        conv_summaries+=("$(echo "$line" | cut -d'|' -f3)")
    done < <(MAX_RESULTS=10 recent-conversations 2>/dev/null || true)

    if [[ ${#conv_ids[@]} -eq 0 ]]; then
        local msg="<i>No recent conversations found</i>"
        if (( topic_id > 0 )); then
            send_message "$topic_id" "$msg"
        else
            send_general_message "$msg"
        fi
        return
    fi

    local output="<b>Recent Conversations</b>\n\nReply with a number to resume:\n\n"
    local i=1
    for idx in "${!conv_ids[@]}"; do
        local escaped_summary
        escaped_summary=$(escape_html "${conv_summaries[$idx]}")
        output+="<b>${i}.</b> ${escaped_summary} — ${conv_ages[$idx]}\n"
        (( i++ )) || true
    done

    # Store resume state so we can pick up the reply
    local resume_tmp="${CONFIG_DIR}/resume_pending.json"
    local ids_json
    ids_json=$(printf '%s\n' "${conv_ids[@]}" | jq -R . | jq -s .)
    local summaries_json
    summaries_json=$(printf '%s\n' "${conv_summaries[@]}" | jq -R . | jq -s .)
    jq -n --argjson ids "$ids_json" --argjson summaries "$summaries_json" --argjson topic "$topic_id" \
        '{ids: $ids, summaries: $summaries, topic_id: $topic, expires: (now + 120 | floor)}' \
        > "$resume_tmp"

    if (( topic_id > 0 )); then
        send_message "$topic_id" "$output"
    else
        send_general_message "$output"
    fi
}

handle_resume_reply() {
    local topic_id="$1" text="$2"
    local resume_tmp="${CONFIG_DIR}/resume_pending.json"

    [[ ! -f "$resume_tmp" ]] && return 1

    # Check expiry
    local expires
    expires=$(jq -r '.expires' "$resume_tmp") || return 1
    local now
    now=$(date +%s)
    if (( now > expires )); then
        rm -f "$resume_tmp"
        return 1
    fi

    # Check if this is a number
    [[ ! "$text" =~ ^[0-9]+$ ]] && return 1

    local pick="$text"
    local count
    count=$(jq '.ids | length' "$resume_tmp")
    if (( pick < 1 || pick > count )); then
        return 1
    fi

    local conv_id conv_summary
    conv_id=$(jq -r --argjson i "$((pick - 1))" '.ids[$i]' "$resume_tmp")
    conv_summary=$(jq -r --argjson i "$((pick - 1))" '.summaries[$i]' "$resume_tmp")
    rm -f "$resume_tmp"

    log "Resuming conversation $conv_id ($conv_summary)"

    local sname
    sname=$(auto_session_name)

    local claude_cmd="cd ${PROJECT_DIR} && claude --resume ${conv_id}"
    tmux new-session -d -s "$sname" -c "$PROJECT_DIR"
    tmux send-keys -t "$sname" "$claude_cmd" Enter

    # Get pane PID for rename tracking
    local pane_pid
    pane_pid=$(tmux list-panes -t "$sname" -F '#{pane_pid}' 2>/dev/null | head -1) || true

    # Check if there's an existing closed topic for this conversation
    local existing_match
    existing_match=$(find_inactive_topic_by_conv "$conv_id") || true
    if [[ -n "$existing_match" ]]; then
        local old_name old_tid
        old_name=$(echo "$existing_match" | cut -d'|' -f1)
        old_tid=$(echo "$existing_match" | cut -d'|' -f2)
        reopen_topic "$old_tid" >/dev/null 2>&1 || true
        edit_topic_name "$old_tid" "${conv_summary:0:128}" >/dev/null 2>&1 || true
        reactivate_topic_mapping "$old_name" "$sname" "${pane_pid:-0}"
        log "Reopened topic $old_tid for resumed '$conv_summary' as '$sname'"

        local escaped_summary
        escaped_summary=$(escape_html "$conv_summary")
        send_message "$old_tid" "Resumed as <code>${sname}</code>. History above ↑"
        local notify_text="Resumed <b>${escaped_summary}</b> — reopened existing topic"
        if (( topic_id > 0 )); then
            send_message "$topic_id" "$notify_text"
        else
            send_general_message "$notify_text"
        fi
        return 0
    fi

    # No existing topic — create a new one
    local response
    response=$(create_topic "${conv_summary:0:128}" "$COLOR_BLUE")
    local new_topic_id
    new_topic_id=$(echo "$response" | jq -r '.result.message_thread_id // empty') || true

    if [[ -n "$new_topic_id" ]]; then
        set_topic_mapping "$sname" "$new_topic_id" "${pane_pid:-0}" "$conv_id"
        log "Resumed '$conv_summary' as '$sname' with topic $new_topic_id"

        local notify_text
        local escaped_summary
        escaped_summary=$(escape_html "$conv_summary")
        notify_text="Resumed <b>${escaped_summary}</b> as <code>${sname}</code>"
        if (( topic_id > 0 )); then
            send_message "$topic_id" "$notify_text"
        else
            send_general_message "$notify_text"
        fi
        send_message "$new_topic_id" "Resumed session. Messages here route to Claude."
    else
        local notify_text="Resumed as <code>${sname}</code> but topic creation failed."
        if (( topic_id > 0 )); then
            send_message "$topic_id" "$notify_text"
        else
            send_general_message "$notify_text"
        fi
    fi

    return 0
}

cmd_kill() {
    local topic_id="$1" target="${2:-}"
    log "Command: /kill $target"

    # Enable with ENABLE_KILL=true in .env
    if [[ "$ENABLE_KILL" != "true" ]]; then
        local msg="<i>/kill is disabled. Set ENABLE_KILL=true in .env to enable.</i>"
        if (( topic_id > 0 )); then
            send_message "$topic_id" "$msg"
        else
            send_general_message "$msg"
        fi
        return
    fi

    if [[ -z "$target" ]]; then
        local msg="Usage: /kill &lt;session-number&gt;\nUse /sessions to see the list."
        if (( topic_id > 0 )); then
            send_message "$topic_id" "$msg"
        else
            send_general_message "$msg"
        fi
        return
    fi

    # Get session list and pick by number
    local -a sessions=()
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        sessions+=("$(echo "$line" | cut -d'|' -f1)")
    done < <(get_claude_sessions)

    if [[ ! "$target" =~ ^[0-9]+$ ]] || (( target < 1 || target > ${#sessions[@]} )); then
        local msg="Invalid session number. Use /sessions to see the list."
        if (( topic_id > 0 )); then
            send_message "$topic_id" "$msg"
        else
            send_general_message "$msg"
        fi
        return
    fi

    local sess_name="${sessions[$((target - 1))]}"
    local sess_topic
    sess_topic=$(get_topic_for_session "$sess_name")

    tmux kill-session -t "$sess_name" 2>/dev/null || true
    mark_topic_inactive "$sess_name"

    if [[ -n "$sess_topic" ]]; then
        close_topic "$sess_topic" >/dev/null 2>&1 || true
    fi

    local msg="Killed session <code>${sess_name}</code>"
    if (( topic_id > 0 )); then
        send_message "$topic_id" "$msg"
    else
        send_general_message "$msg"
    fi
    log "Killed session '$sess_name'"
}

cmd_approval() {
    local topic_id="$1" answer="${2:-}"
    log "Command: /approval $answer"

    if (( topic_id == 0 )); then
        send_general_message "<i>/approval must be used in a session topic</i>"
        return
    fi

    local session_name
    session_name=$(get_session_for_topic "$topic_id")
    if [[ -z "$session_name" ]]; then
        send_message "$topic_id" "<i>No session mapped to this topic</i>"
        return
    fi

    if ! tmux has-session -t "$session_name" 2>/dev/null; then
        send_message "$topic_id" "<i>Session ended.</i>"
        mark_topic_inactive "$session_name"
        return
    fi

    case "$answer" in
        yes|y)
            tmux send-keys -t "${session_name}:1.1" "y" Enter
            send_message "$topic_id" "Approved ✓"
            ;;
        no|n)
            tmux send-keys -t "${session_name}:1.1" "n" Enter
            send_message "$topic_id" "Denied ✗"
            ;;
        *)
            send_message "$topic_id" "Usage: <code>/approval yes</code> or <code>/approval no</code>
Shorthand: <code>/approval y</code> / <code>/approval n</code>

Use this to respond to Claude's permission prompts."
            ;;
    esac
}

