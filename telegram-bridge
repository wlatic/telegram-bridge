cmd_restart() {
    local topic_id="$1"
    log "Command: /restart"

    if (( topic_id == 0 )); then
        send_general_message "<i>/restart must be used in a session topic</i>"
        return
    fi

    local session_name
    session_name=$(get_session_for_topic "$topic_id")
    if [[ -z "$session_name" ]]; then
        send_message "$topic_id" "<i>No session mapped to this topic</i>"
        return
    fi

    # Get conversation ID before killing
    local conv_id=""
    # Try state.json first
    conv_id=$(jq -r --arg s "$session_name" '.topics[$s].conv_id // empty' "$STATE_FILE" 2>/dev/null) || true
    # Fallback to live detection
    if [[ -z "$conv_id" ]] && tmux has-session -t "$session_name" 2>/dev/null; then
        conv_id=$(get_conv_id_for_session "$session_name") || true
    fi

    if [[ -z "$conv_id" ]]; then
        send_message "$topic_id" "<i>Cannot restart — no conversation ID found. Use /close and /new instead.</i>"
        return
    fi

    send_message "$topic_id" "Restarting session..."

    # Stop watcher
    stop_watcher "$session_name"

    # Kill the tmux session
    tmux kill-session -t "$session_name" 2>/dev/null || true

    # Clean up working state
    rm -f "${CONFIG_DIR}/working_${session_name}" "${CONFIG_DIR}/activity_${session_name}" \
          "${CONFIG_DIR}/agent_status_${session_name}" "${CONFIG_DIR}/working_dots_${session_name}" \
          "${CONFIG_DIR}/permission_notified_${session_name}"

    # Create new tmux session with the same name
    tmux new-session -d -s "$session_name" -c "$PROJECT_DIR"
    tmux send-keys -t "${session_name}:1.1" "cd ${PROJECT_DIR} && claude --dangerously-skip-permissions --resume ${conv_id}" Enter

    # Get new pane PID
    local pane_pid
    pane_pid=$(tmux list-panes -t "$session_name" -F '#{pane_pid}' 2>/dev/null | head -1) || true

    # Update state with new pane PID
    local tmp="${STATE_FILE}.tmp"
    jq --arg s "$session_name" --arg pid "${pane_pid:-0}" --arg cid "$conv_id" \
        '.topics[$s].pane_pid = $pid | .topics[$s].conv_id = $cid' \
        "$STATE_FILE" > "$tmp" && mv "$tmp" "$STATE_FILE"

    # Start a new watcher
    start_watcher "$session_name" "$topic_id"

    send_message "$topic_id" "🔄 Restarted session with same conversation"
    log "Restarted session '$session_name' with conv_id=$conv_id"
}

