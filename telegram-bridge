# ── JSONL transcript watcher ──────────────────────────────────────────

# Start a persistent JSONL watcher for a session.
# Tails the conversation JSONL file and sends new assistant/user messages
# to the mapped Telegram topic.
start_watcher() {
    local session_name="$1" topic_id="$2"
    local watcher_pid_file="${WATCHERS_DIR}/${session_name}.pid"

    # Kill existing watcher for this session
    stop_watcher "$session_name"

    (
        # Give the session a moment to start and create a JSONL
        local conv_id=""
        local jsonl_file=""
        local wait_count=0

        while [[ -z "$conv_id" ]] && (( wait_count < 60 )); do
            conv_id=$(get_conv_id_for_session "$session_name" 2>/dev/null) || true
            if [[ -n "$conv_id" ]]; then
                jsonl_file="${CONV_DIR}/${conv_id}.jsonl"
                if [[ -f "$jsonl_file" ]]; then
                    break
                fi
                conv_id=""
            fi
            sleep 3
            (( wait_count++ )) || true
            # Check session still alive
            if ! tmux has-session -t "$session_name" 2>/dev/null; then
                exit 0
            fi
        done

        if [[ -z "$conv_id" || ! -f "$jsonl_file" ]]; then
            exit 0
        fi

        log "Watcher: started for '$session_name' conv=$conv_id topic=$topic_id"

        local offset_file="${OFFSETS_DIR}/${conv_id}.offset"
        local last_sent_file="${LAST_SENT_DIR}/${session_name}"
        local last_send_time=0

        # Initialize offset to current file size (skip history)
        if [[ ! -f "$offset_file" ]]; then
            wc -c < "$jsonl_file" > "$offset_file"
        fi

        while true; do
            sleep 1

            # Check session still alive
            if ! tmux has-session -t "$session_name" 2>/dev/null; then
                log "Watcher: session '$session_name' gone, exiting"
                break
            fi

            # Check JSONL still exists (conversation ID might change on compaction)
            if [[ ! -f "$jsonl_file" ]]; then
                # Try to re-resolve conversation ID
                local new_conv_id
                new_conv_id=$(get_conv_id_for_session "$session_name" 2>/dev/null) || true
                if [[ -n "$new_conv_id" && -f "${CONV_DIR}/${new_conv_id}.jsonl" ]]; then
                    conv_id="$new_conv_id"
                    jsonl_file="${CONV_DIR}/${conv_id}.jsonl"
                    offset_file="${OFFSETS_DIR}/${conv_id}.offset"
                    if [[ ! -f "$offset_file" ]]; then
                        wc -c < "$jsonl_file" > "$offset_file"
                    fi
                    log "Watcher: conv ID changed for '$session_name', now $conv_id"
                else
                    continue
                fi
            fi

            local current_size
            current_size=$(wc -c < "$jsonl_file" 2>/dev/null) || continue
            local stored_offset
            stored_offset=$(cat "$offset_file" 2>/dev/null) || stored_offset=0
            stored_offset="${stored_offset:-0}"

            # Nothing new — check if Working... should be cleared (idle)
            if (( current_size <= stored_offset )); then
                # No new JSONL data — check if Claude is waiting for input
                local working_file="${CONFIG_DIR}/working_${session_name}"
                if [[ -f "$working_file" ]]; then
                    local w_id
                    w_id=$(cat "$working_file" 2>/dev/null) || true

                    # ── Hook-based status detection (preferred) ──
                    local hook_status_file="${CONFIG_DIR}/hook_status_${conv_id}.json"
                    local used_hook=false

                    if [[ -f "$hook_status_file" ]]; then
                        local hook_state hook_ts hook_tool hook_agent
                        hook_state=$(jq -r '.state // empty' "$hook_status_file" 2>/dev/null) || true
                        hook_ts=$(jq -r '.timestamp // 0' "$hook_status_file" 2>/dev/null) || true

                        if [[ -n "$hook_state" ]]; then
                            used_hook=true
                            # Update activity timestamp from hook
                            local activity_file="${CONFIG_DIR}/activity_${session_name}"
                            echo "$hook_ts" > "$activity_file"

                            case "$hook_state" in
                                idle)
                                    # Stop hook fired — but verify with pane + cooldown
                                    local now_cool
                                    now_cool=$(date +%s)
                                    if (( now_cool - hook_ts < 30 )); then
                                        continue
                                    fi
                                    # Double-check: pane must show ❯ and no @ agents
                                    local pane_verify
                                    pane_verify=$(tmux capture-pane -t "${session_name}:1.1" -p 2>/dev/null | grep -v '^\s*$' | tail -10) || true
                                    local verify_prompt=false
                                    local verify_agents=false
                                    echo "$pane_verify" | grep -q '❯' && verify_prompt=true
                                    echo "$pane_verify" | grep -q ' @' && verify_agents=true
                                    if [[ "$verify_prompt" != "true" || "$verify_agents" == "true" ]]; then
                                        continue
                                    fi
                                    if [[ -n "$w_id" ]]; then
                                        edit_message "$w_id" "✓ Done" "" >/dev/null 2>&1 || true
                                    fi
                                    rm -f "$working_file" "${CONFIG_DIR}/activity_${session_name}" "${CONFIG_DIR}/agent_status_${session_name}" "${CONFIG_DIR}/working_dots_${session_name}" "$hook_status_file"
                                    ;;
                                tool_use)
                                    # Claude is using a tool — show which one
                                    hook_tool=$(jq -r '.tool // "unknown"' "$hook_status_file" 2>/dev/null) || hook_tool="unknown"
                                    local status_text="Working... (${hook_tool})"
                                    local prev_status_file="${CONFIG_DIR}/agent_status_${session_name}"
                                    local prev_status
                                    prev_status=$(cat "$prev_status_file" 2>/dev/null) || true
                                    if [[ "$status_text" != "$prev_status" && -n "$w_id" ]]; then
                                        edit_message "$w_id" "$status_text" "" >/dev/null 2>&1 || true
                                        echo "$status_text" > "$prev_status_file"
                                    fi
                                    ;;
                                agent_running)
                                    # Agent spawned — show agent name
                                    hook_agent=$(jq -r '.agent // "agent"' "$hook_status_file" 2>/dev/null) || hook_agent="agent"
                                    local status_text="Working... (@${hook_agent})"
                                    local prev_status_file="${CONFIG_DIR}/agent_status_${session_name}"
                                    local prev_status
                                    prev_status=$(cat "$prev_status_file" 2>/dev/null) || true
                                    if [[ "$status_text" != "$prev_status" && -n "$w_id" ]]; then
                                        edit_message "$w_id" "$status_text" "" >/dev/null 2>&1 || true
                                        echo "$status_text" > "$prev_status_file"
                                    fi
                                    ;;
                                agent_done)
                                    # Agent finished but orchestrator may continue — keep working
                                    hook_agent=$(jq -r '.agent // "agent"' "$hook_status_file" 2>/dev/null) || hook_agent="agent"
                                    local status_text="Working... (@${hook_agent} done)"
                                    local prev_status_file="${CONFIG_DIR}/agent_status_${session_name}"
                                    local prev_status
                                    prev_status=$(cat "$prev_status_file" 2>/dev/null) || true
                                    if [[ "$status_text" != "$prev_status" && -n "$w_id" ]]; then
                                        edit_message "$w_id" "$status_text" "" >/dev/null 2>&1 || true
                                        echo "$status_text" > "$prev_status_file"
                                    fi
                                    ;;
                                *)
                                    # active, notification, etc. — keep Working alive
                                    ;;
                            esac
                        fi
                    fi

                    # ── Fallback: pane-scraping (no hook status file) ──
                    if [[ "$used_hook" == "false" ]]; then
                        local pane_content
                        pane_content=$(tmux capture-pane -t "${session_name}:1.1" -p 2>/dev/null | grep -v '^\s*$' | tail -10) || true
                        local has_prompt=false
                        local has_agents=false
                        echo "$pane_content" | grep -q '❯' && has_prompt=true
                        echo "$pane_content" | grep -q ' @' && has_agents=true

                        if [[ "$has_prompt" == "true" && "$has_agents" == "false" ]]; then
                            local activity_file="${CONFIG_DIR}/activity_${session_name}"
                            local last_activity=0
                            [[ -f "$activity_file" ]] && last_activity=$(cat "$activity_file" 2>/dev/null) || true
                            local now_cool
                            now_cool=$(date +%s)
                            if (( now_cool - last_activity < 30 )); then
                                continue
                            fi
                            if [[ -n "$w_id" ]]; then
                                edit_message "$w_id" "✓ Done" "" >/dev/null 2>&1 || true
                            fi
                            rm -f "$working_file" "${CONFIG_DIR}/activity_${session_name}" "${CONFIG_DIR}/agent_status_${session_name}" "${CONFIG_DIR}/working_dots_${session_name}"
                        elif [[ -n "$w_id" ]]; then
                            local dots_file="${CONFIG_DIR}/working_dots_${session_name}"
                            local dot_count
                            dot_count=$(cat "$dots_file" 2>/dev/null) || dot_count=0
                            local now_sec
                            now_sec=$(date +%s)
                            local last_dot_time
                            last_dot_time=$(stat -c %Y "$dots_file" 2>/dev/null) || last_dot_time=0
                            if (( now_sec - last_dot_time >= 30 )); then
                                (( dot_count++ )) || true
                                # Cycle 1-3 dots
                                if (( dot_count > 3 )); then dot_count=1; fi
                                echo "$dot_count" > "$dots_file"
                            fi
                            local dot_str=""
                            for (( d=0; d<dot_count; d++ )); do dot_str+="."; done
                            local status_text="Working...${dot_str}"
                            if [[ "$has_agents" == "true" ]]; then
                                local agent_name
                                agent_name=$(echo "$pane_content" | grep -o ' @[a-zA-Z0-9_-]*' | head -1 | tr -d ' ') || true
                                [[ -n "$agent_name" ]] && status_text="Working...${dot_str} (${agent_name})"
                            fi
                            local prev_status_file="${CONFIG_DIR}/agent_status_${session_name}"
                            local prev_status
                            prev_status=$(cat "$prev_status_file" 2>/dev/null) || true
                            if [[ "$status_text" != "$prev_status" ]]; then
                                edit_message "$w_id" "$status_text" "" >/dev/null 2>&1 || true
                                echo "$status_text" > "$prev_status_file"
                            fi
                        fi
                    fi
                fi

                # Permission prompt detection
                local permission_notified_file="${CONFIG_DIR}/permission_notified_${session_name}"
                local perm_pane_content
                perm_pane_content=$(tmux capture-pane -t "${session_name}:1.1" -p 2>/dev/null | grep -v '^\s*$' | tail -15) || true
                local has_permission_prompt=false
                if echo "$perm_pane_content" | grep -qE '(Allow once|Allow always|Always allow|Deny)'; then
                    has_permission_prompt=true
                fi

                if [[ "$has_permission_prompt" == "true" ]]; then
                    if [[ ! -f "$permission_notified_file" ]]; then
                        send_message "$topic_id" "⚠️ Permission prompt — use /approval yes or /approval no" >/dev/null 2>&1 || true
                        touch "$permission_notified_file"
                    fi
                else
                    # Prompt gone — clear notification tracking
                    rm -f "$permission_notified_file"
                fi

                continue
            fi

            # Read new bytes
            local new_data
            new_data=$(tail -c +"$((stored_offset + 1))" "$jsonl_file" 2>/dev/null) || continue

            # Update offset immediately
            echo "$current_size" > "$offset_file"

            # Process each line
            while IFS= read -r line; do
                [[ -z "$line" ]] && continue

                local msg_type
                msg_type=$(echo "$line" | jq -r '.type // empty' 2>/dev/null) || continue

                # Skip pure noise types (no activity signal)
                [[ "$msg_type" == "file-history-snapshot" || "$msg_type" == "system" ]] && continue

                # Track activity for Working... indicator (assistant, user, queue-operation all count)
                local working_file="${CONFIG_DIR}/working_${session_name}"
                local activity_file="${CONFIG_DIR}/activity_${session_name}"
                echo "$(date +%s)" > "$activity_file"

                # Show task notifications from queue-operations
                if [[ "$msg_type" == "queue-operation" ]]; then
                    local operation
                    operation=$(echo "$line" | jq -r '.operation // empty' 2>/dev/null) || true
                    if [[ "$operation" == "enqueue" ]]; then
                        local q_content
                        q_content=$(echo "$line" | jq -r '.content // empty' 2>/dev/null) || true
                        if [[ -n "$q_content" && "$q_content" == *"<task-notification>"* ]]; then
                            # Extract task summary
                            local task_status task_summary
                            task_status=$(echo "$q_content" | grep -oP '(?<=<status>).*(?=</status>)' | head -1) || true
                            task_summary=$(echo "$q_content" | grep -oP '(?<=<summary>).*(?=</summary>)' | head -1) || true
                            if [[ -n "$task_summary" ]]; then
                                local escaped_summary
                                escaped_summary=$(escape_html "${task_summary:0:200}")
                                send_message "$topic_id" "📋 Task ${task_status:-update}: ${escaped_summary}" "HTML" >/dev/null 2>&1 || true
                            fi
                        fi
                    fi
                    continue
                fi

                if [[ "$msg_type" == "assistant" ]]; then
                    # Extract text content from assistant message
                    local text_content
                    text_content=$(echo "$line" | jq -r '
                        .message.content[]? |
                        select(.type == "text") |
                        .text // empty
                    ' 2>/dev/null) || continue

                    [[ -z "$text_content" ]] && continue

                    # Rate limit: 1 message/sec
                    local now_ms
                    now_ms=$(date +%s)
                    if (( now_ms <= last_send_time )); then
                        sleep 1
                    fi
                    last_send_time=$(date +%s)

                    local escaped_text
                    escaped_text=$(escape_html "$text_content")

                    # Build message: short = plain, long = preview + expandable
                    local final_msg=""
                    if (( ${#text_content} <= 200 )); then
                        final_msg="$escaped_text"
                    elif (( ${#escaped_text} <= 3800 )); then
                        local preview
                        preview=$(escape_html "${text_content:0:200}")
                        final_msg="${preview}...
<blockquote expandable>${escaped_text}</blockquote>"
                    else
                        local preview
                        preview=$(escape_html "${text_content:0:200}")
                        final_msg="${preview}...
<blockquote expandable>${escaped_text:0:3600}</blockquote>"
                    fi

                    # Always send as new message (don't replace Working...)
                    local send_result
                    send_result=$(send_message "$topic_id" "$final_msg" "HTML" 2>/dev/null) || true
                    local send_ok
                    send_ok=$(echo "$send_result" | jq -r '.ok // false' 2>/dev/null) || true
                    if [[ "$send_ok" != "true" ]]; then
                        send_message "$topic_id" "${text_content:0:4000}" "" >/dev/null 2>&1 || true
                    fi

                    # If very long, send remaining chunks
                    if (( ${#escaped_text} > 3800 )); then
                        local chunk_offset=3600
                        while (( chunk_offset < ${#escaped_text} )); do
                            sleep 1
                            local chunk="${escaped_text:$chunk_offset:3800}"
                            send_message "$topic_id" "<blockquote expandable>${chunk}</blockquote>" "HTML" >/dev/null 2>&1 || true
                            (( chunk_offset += 3800 )) || true
                        done
                    fi

                elif [[ "$msg_type" == "human" || "$msg_type" == "user" ]]; then
                    # Skip tool_result entries — they're not user messages
                    local has_tool_result
                    has_tool_result=$(echo "$line" | jq -r '.message.content[]? | select(.type == "tool_result") | .type' 2>/dev/null | head -1) || true
                    [[ -n "$has_tool_result" ]] && continue

                    # Extract only text content from user messages
                    local user_text
                    user_text=$(echo "$line" | jq -r '
                        .message.content[]? |
                        select(.type == "text") |
                        .text // empty
                    ' 2>/dev/null) || continue

                    # Fallback: content might be a plain string
                    if [[ -z "$user_text" ]]; then
                        local content_type
                        content_type=$(echo "$line" | jq -r '.message.content | type' 2>/dev/null) || continue
                        if [[ "$content_type" == "string" ]]; then
                            user_text=$(echo "$line" | jq -r '.message.content' 2>/dev/null) || continue
                        else
                            continue
                        fi
                    fi

                    [[ -z "$user_text" ]] && continue

                    # Skip internal Claude messages (agent orchestration, system context)
                    if [[ "$user_text" == *"<task-notification>"* || "$user_text" == *"<teammate-message>"* || "$user_text" == *"<system-reminder>"* ]]; then
                        continue
                    fi

                    # Skip if this was sent from Telegram (avoid echo)
                    if [[ -f "$last_sent_file" ]]; then
                        local last_sent
                        last_sent=$(cat "$last_sent_file" 2>/dev/null) || true
                        if [[ "$user_text" == "$last_sent" ]]; then
                            rm -f "$last_sent_file"
                            continue
                        fi
                    fi

                    # Rate limit
                    local now_ms
                    now_ms=$(date +%s)
                    if (( now_ms <= last_send_time )); then
                        sleep 1
                    fi
                    last_send_time=$(date +%s)

                    local escaped_user
                    escaped_user=$(escape_html "$user_text")
                    # Truncate very long user messages
                    if (( ${#escaped_user} > 3900 )); then
                        escaped_user="${escaped_user:0:3900}..."
                    fi
                    send_message "$topic_id" "👤 ${escaped_user}" "HTML" >/dev/null 2>&1 || true

                    # Send "Working..." so Telegram shows Claude is processing
                    # Clear any existing Working... first
                    local working_file="${CONFIG_DIR}/working_${session_name}"
                    if [[ -f "$working_file" ]]; then
                        local old_w_id
                        old_w_id=$(cat "$working_file" 2>/dev/null) || true
                        [[ -n "$old_w_id" ]] && edit_message "$old_w_id" "✓ Done" "" >/dev/null 2>&1 || true
                        rm -f "$working_file"
                    fi
                    local working_response
                    working_response=$(send_message "$topic_id" "Working...")
                    local w_msg_id
                    w_msg_id=$(echo "$working_response" | jq -r '.result.message_id // empty') || true
                    if [[ -n "$w_msg_id" ]]; then
                        echo "$w_msg_id" > "$working_file"
                        # Watcher handles dots and agent status — no background process needed
                    fi
                fi

            done <<< "$new_data"
        done

        # Cleanup
        rm -f "$watcher_pid_file"
        log "Watcher: exited for '$session_name'"
    ) &

    echo $! > "$watcher_pid_file"
    log "Watcher: launched PID $! for '$session_name' topic=$topic_id"
}

# Stop a watcher for a session
stop_watcher() {
    local session_name="$1"
    local watcher_pid_file="${WATCHERS_DIR}/${session_name}.pid"

    if [[ -f "$watcher_pid_file" ]]; then
        local old_pid
        old_pid=$(cat "$watcher_pid_file" 2>/dev/null) || true
        if [[ -n "$old_pid" ]] && kill -0 "$old_pid" 2>/dev/null; then
            kill "$old_pid" 2>/dev/null || true
            wait "$old_pid" 2>/dev/null || true
        fi
        rm -f "$watcher_pid_file"
    fi
}

# Check if a watcher is running for a session
watcher_running() {
    local session_name="$1"
    local watcher_pid_file="${WATCHERS_DIR}/${session_name}.pid"

    if [[ -f "$watcher_pid_file" ]]; then
        local pid
        pid=$(cat "$watcher_pid_file" 2>/dev/null) || true
        if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
            return 0
        fi
        rm -f "$watcher_pid_file"
    fi
    return 1
}

# ── Message routing ───────────────────────────────────────────────────

route_message() {
    local topic_id="$1" text="$2"

    # Find which session this topic maps to
    local session_name
    session_name=$(get_session_for_topic "$topic_id")

    if [[ -z "$session_name" ]]; then
        log "No session mapped to topic $topic_id"
        return
    fi

    # Check session still exists
    if ! tmux has-session -t "$session_name" 2>/dev/null; then
        log "Session '$session_name' no longer exists"
        mark_topic_inactive "$session_name"
        send_message "$topic_id" "<i>Session ended.</i>"
        return
    fi

    log "Routing message to session '$session_name': ${text:0:50}..."

    # Record what we sent so the JSONL watcher can skip the echo
    local last_sent_file="${LAST_SENT_DIR}/${session_name}"
    echo "$text" > "$last_sent_file"

    # Check if Claude is busy — JSONL modified in last 10 seconds = busy
    local is_busy=false
    local conv_id_check
    conv_id_check=$(get_conv_id_for_session "$session_name" 2>/dev/null) || true
    if [[ -n "$conv_id_check" ]]; then
        local jsonl_file="${CONV_DIR}/${conv_id_check}.jsonl"
        if [[ -f "$jsonl_file" ]]; then
            local jsonl_mtime now_check
            jsonl_mtime=$(stat -c %Y "$jsonl_file" 2>/dev/null) || jsonl_mtime=0
            now_check=$(date +%s)
            if (( now_check - jsonl_mtime < 10 )); then
                is_busy=true
            fi
        fi
    fi

    # Inject message into tmux session
    tmux send-keys -t "${session_name}:1.1" -- "$text" Enter

    # Send delivery confirmation
    if [[ "$is_busy" == "true" ]]; then
        send_message "$topic_id" "📨 Message queued" >/dev/null 2>&1 || true
    else
        send_message "$topic_id" "Message sent ✓" >/dev/null 2>&1 || true
    fi

    # Clear any existing Working... before creating new one
    local working_file="${CONFIG_DIR}/working_${session_name}"
    if [[ -f "$working_file" ]]; then
        local old_w_id
        old_w_id=$(cat "$working_file" 2>/dev/null) || true
        [[ -n "$old_w_id" ]] && edit_message "$old_w_id" "✓ Done" "" >/dev/null 2>&1 || true
        rm -f "$working_file"
    fi

    # Send "Working..." message and store its ID for the watcher to edit
    local response
    response=$(send_message "$topic_id" "Working...")
    local working_msg_id
    working_msg_id=$(echo "$response" | jq -r '.result.message_id // empty') || true

    if [[ -n "$working_msg_id" ]]; then
        echo "$working_msg_id" > "$working_file"
        # Watcher handles dots and agent status — no background process needed
    fi

    # Ensure watcher is running for this session
    if ! watcher_running "$session_name"; then
        start_watcher "$session_name" "$topic_id"
    fi
}

# ── Session detection loop ────────────────────────────────────────────

check_sessions() {
    # Get current Claude sessions with PIDs
    local -a current_sessions=()
    local -a current_pids=()
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        current_sessions+=("$(echo "$line" | cut -d'|' -f1)")
        current_pids+=("$(echo "$line" | cut -d'|' -f2)")
    done < <(get_claude_sessions)

    # Build list of mapped sessions that are "gone" (not in current)
    local -a gone_sessions=()
    local mapped_sessions
    mapped_sessions=$(jq -r '.topics | to_entries[] | select(.value.active == true) | .key' "$STATE_FILE" 2>/dev/null) || true

    while IFS= read -r sess; do
        [[ -z "$sess" ]] && continue
        local found=false
        for current in "${current_sessions[@]+"${current_sessions[@]}"}"; do
            [[ "$current" == "$sess" ]] && found=true && break
        done
        [[ "$found" == "false" ]] && gone_sessions+=("$sess")
    done <<< "$mapped_sessions"

    # FIRST: Detect renames — a "new" session with the same PID as a "gone" session
    local -a handled_new=()
    local -a handled_gone=()

    for idx in "${!current_sessions[@]}"; do
        local sess="${current_sessions[$idx]}"
        local pid="${current_pids[$idx]}"

        # Skip if already has a topic
        local existing_topic
        existing_topic=$(get_topic_for_session "$sess")
        [[ -n "$existing_topic" ]] && continue

        # This is a "new" session — check if any gone session has the same PID
        for gone_sess in "${gone_sessions[@]+"${gone_sessions[@]}"}"; do
            local gone_pid
            gone_pid=$(jq -r --arg s "$gone_sess" '.topics[$s].pane_pid // "0"' "$STATE_FILE" 2>/dev/null) || true

            if [[ -n "$pid" && "$pid" != "0" && "$pid" == "$gone_pid" ]]; then
                # Same PID = rename, not a new session
                local tid
                tid=$(get_topic_for_session "$gone_sess")
                if [[ -n "$tid" ]]; then
                    edit_topic_name "$tid" "${sess:0:128}" >/dev/null 2>&1 || true
                    rename_topic_mapping "$gone_sess" "$sess"
                    # Update PID in state
                    local tmp="${STATE_FILE}.tmp"
                    jq --arg s "$sess" --arg pid "$pid" '.topics[$s].pane_pid = $pid' "$STATE_FILE" > "$tmp" && mv "$tmp" "$STATE_FILE"
                    log "Detected rename: '$gone_sess' → '$sess', updated topic $tid"
                    # Migrate watcher: stop old, start new if not running
                    stop_watcher "$gone_sess"
                    if ! watcher_running "$sess"; then
                        start_watcher "$sess" "$tid"
                    fi
                    handled_new+=("$sess")
                    handled_gone+=("$gone_sess")
                fi
                break
            fi
        done
    done

    # SECOND: Create topics for sessions without active topics
    for idx in "${!current_sessions[@]}"; do
        local sess="${current_sessions[$idx]}"
        local pid="${current_pids[$idx]}"

        local existing_topic
        existing_topic=$(get_topic_for_session "$sess")
        [[ -n "$existing_topic" ]] && continue

        # Skip if this was handled as a rename
        local was_rename=false
        for h in "${handled_new[@]+"${handled_new[@]}"}"; do
            [[ "$h" == "$sess" ]] && was_rename=true && break
        done
        [[ "$was_rename" == "true" ]] && continue

        # Get conversation ID for state tracking
        local conv_id
        conv_id=$(get_conv_id_for_session "$sess") || true

        # Clean up any stale inactive entry for this session name
        local tmp="${STATE_FILE}.tmp"
        jq --arg s "$sess" 'if .topics[$s].active == false then del(.topics[$s]) else . end' \
            "$STATE_FILE" > "$tmp" && mv "$tmp" "$STATE_FILE"

        # Create a fresh topic
        log "Creating topic for session: $sess"
        local response
        response=$(create_topic "$sess" "$COLOR_GREEN")
        local new_topic_id
        new_topic_id=$(echo "$response" | jq -r '.result.message_thread_id // empty') || true
        if [[ -n "$new_topic_id" ]]; then
            set_topic_mapping "$sess" "$new_topic_id" "$pid" "$conv_id"
            log "Created topic $new_topic_id for session $sess"
            start_watcher "$sess" "$new_topic_id"
        else
            log "Failed to create topic for session $sess"
        fi
    done

    # THIRD: Mark genuinely gone sessions as inactive (not renames)
    for gone_sess in "${gone_sessions[@]+"${gone_sessions[@]}"}"; do
        local was_rename=false
        for h in "${handled_gone[@]+"${handled_gone[@]}"}"; do
            [[ "$h" == "$gone_sess" ]] && was_rename=true && break
        done
        [[ "$was_rename" == "true" ]] && continue

        log "Session '$gone_sess' gone, deleting topic"
        stop_watcher "$gone_sess"
        local tid
        tid=$(get_topic_for_session "$gone_sess")
        if [[ -n "$tid" ]]; then
            delete_topic "$tid" >/dev/null 2>&1 || true
        fi
        mark_topic_inactive "$gone_sess"
    done

    # FOURTH: Ensure watchers are running for all active sessions with topics
    for idx in "${!current_sessions[@]}"; do
        local sess="${current_sessions[$idx]}"
        local topic
        topic=$(get_topic_for_session "$sess") || true
        if [[ -n "$topic" ]] && ! watcher_running "$sess"; then
            start_watcher "$sess" "$topic"
        fi
    done
}

# ── Clean shutdown ────────────────────────────────────────────────────

cleanup() {
    log "Shutting down..."
    # Kill all JSONL watchers
    for pid_file in "${WATCHERS_DIR}"/*.pid; do
        [[ -f "$pid_file" ]] || continue
        local pid
        pid=$(cat "$pid_file" 2>/dev/null) || true
        if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
            kill "$pid" 2>/dev/null || true
        fi
        rm -f "$pid_file"
    done
    # Clean up any leftover monitor PIDs from old version
    for pid_file in "${CONFIG_DIR}"/monitor_*.pid; do
        [[ -f "$pid_file" ]] || continue
        local pid
        pid=$(cat "$pid_file" 2>/dev/null) || true
        if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
            kill "$pid" 2>/dev/null || true
        fi
        rm -f "$pid_file"
    done
    log "Shutdown complete"
    exit 0
}

trap cleanup SIGTERM SIGINT

# ── File & voice handling ─────────────────────────────────────────────

# Download a file from Telegram by file_id, save to TMP_DIR with given filename
tg_download_file() {
    local file_id="$1" filename="$2"
    local dest="${TMP_DIR}/${filename}"

    # Get file path from Telegram
    local response
    response=$(curl -s "${API}/getFile" -H "Content-Type: application/json" \
        -d "$(jq -n --arg fid "$file_id" '{file_id: $fid}')") || true

    local file_path
    file_path=$(echo "$response" | jq -r '.result.file_path // empty' 2>/dev/null) || true

    if [[ -z "$file_path" ]]; then
        log "Failed to get file path for file_id=$file_id"
        return 1
    fi

    # Download the file
    curl -s -o "$dest" "https://api.telegram.org/file/bot${BOT_TOKEN}/${file_path}" || return 1
    log "Downloaded file: $dest"
    echo "$dest"
}

# Handle a file message (document, photo, video, audio)
handle_file_message() {
    local message="$1" topic_id="$2"
    local file_id="" filename="" file_type=""
    local timestamp
    timestamp=$(date +%s)

    # Detect file type and extract file_id / filename
    if echo "$message" | jq -e '.document' >/dev/null 2>&1; then
        file_type="document"
        file_id=$(echo "$message" | jq -r '.document.file_id // empty')
        filename=$(echo "$message" | jq -r '.document.file_name // empty')
        [[ -z "$filename" ]] && filename="document_${timestamp}"
    elif echo "$message" | jq -e '.photo' >/dev/null 2>&1; then
        file_type="photo"
        # Pick the largest photo (last element in the array)
        file_id=$(echo "$message" | jq -r '.photo[-1].file_id // empty')
        filename="photo_${timestamp}.jpg"
    elif echo "$message" | jq -e '.video' >/dev/null 2>&1; then
        file_type="video"
        file_id=$(echo "$message" | jq -r '.video.file_id // empty')
        filename="video_${timestamp}.mp4"
    elif echo "$message" | jq -e '.audio' >/dev/null 2>&1; then
        file_type="audio"
        file_id=$(echo "$message" | jq -r '.audio.file_id // empty')
        filename=$(echo "$message" | jq -r '.audio.file_name // empty')
        [[ -z "$filename" ]] && filename="audio_${timestamp}.mp3"
    elif echo "$message" | jq -e '.voice' >/dev/null 2>&1; then
        file_type="voice"
        file_id=$(echo "$message" | jq -r '.voice.file_id // empty')
        filename="voice_${timestamp}.ogg"
    else
        return 1  # No file detected
    fi

    if [[ -z "$file_id" ]]; then
        return 1
    fi

    log "File detected: type=$file_type file_id=${file_id:0:20}... filename=$filename"

    # Download the file
    local dest
    dest=$(tg_download_file "$file_id" "$filename") || {
        send_message "$topic_id" "<i>Failed to download file</i>"
        return 0
    }

    # Voice messages get special handling — transcribe
    if [[ "$file_type" == "voice" ]]; then
        handle_voice_transcription "$dest" "$filename" "$topic_id"
        return 0
    fi

    # Confirm download
    send_message "$topic_id" "📎 File saved to <code>${dest}</code>"

    # If mapped to a session, notify Claude
    if (( topic_id > 0 )); then
        local session_name
        session_name=$(get_session_for_topic "$topic_id")
        if [[ -n "$session_name" ]] && tmux has-session -t "$session_name" 2>/dev/null; then
            tmux send-keys -t "${session_name}:1.1" "A file has been uploaded to ${dest} — please read it" Enter
        fi
    fi

    return 0
}

# Handle voice message transcription
handle_voice_transcription() {
    local filepath="$1" filename="$2" topic_id="$3"
    local transcription=""

    if [[ -n "$GROQ_API_KEY" ]]; then
        log "Transcribing voice with Groq Whisper"
        local response
        response=$(curl -s -X POST "https://api.groq.com/openai/v1/audio/transcriptions" \
            -H "Authorization: Bearer ${GROQ_API_KEY}" \
            -F "file=@${filepath}" \
            -F "model=whisper-large-v3") || true
        transcription=$(echo "$response" | jq -r '.text // empty' 2>/dev/null) || true
    elif [[ -n "$OPENAI_API_KEY" ]]; then
        log "Transcribing voice with OpenAI Whisper"
        local response
        response=$(curl -s -X POST "https://api.openai.com/v1/audio/transcriptions" \
            -H "Authorization: Bearer ${OPENAI_API_KEY}" \
            -F "file=@${filepath}" \
            -F "model=whisper-1") || true
        transcription=$(echo "$response" | jq -r '.text // empty' 2>/dev/null) || true
    else
        send_message "$topic_id" "<i>Voice transcription unavailable — set GROQ_API_KEY or OPENAI_API_KEY in .env</i>"
        rm -f "$filepath"
        return
    fi

    # Clean up voice file
    rm -f "$filepath"

    if [[ -z "$transcription" ]]; then
        send_message "$topic_id" "<i>Voice transcription failed</i>"
        return
    fi

    log "Voice transcription: ${transcription:0:80}..."

    # Send transcription to topic
    local escaped_transcription
    escaped_transcription=$(escape_html "$transcription")
    send_message "$topic_id" "🎤 <i>${escaped_transcription}</i>"

    # If mapped to a session, inject the transcription
    if (( topic_id > 0 )); then
        local session_name
        session_name=$(get_session_for_topic "$topic_id")
        if [[ -n "$session_name" ]] && tmux has-session -t "$session_name" 2>/dev/null; then
            # Record what we sent so the JSONL watcher can skip the echo
            local last_sent_file="${LAST_SENT_DIR}/${session_name}"
            echo "$transcription" > "$last_sent_file"
            tmux send-keys -t "${session_name}:1.1" -- "$transcription" Enter
        fi
    fi
}

# ── Main loop ─────────────────────────────────────────────────────────

main_loop() {
    log "Telegram bridge started"
    init_state

    local last_session_check=0

    while true; do
        local now
        now=$(date +%s)

        # Session detection check every SESSION_CHECK_INTERVAL seconds
        if (( now - last_session_check >= SESSION_CHECK_INTERVAL )); then
            check_sessions
            last_session_check="$now"
        fi

        # Poll for updates
        local offset
        offset=$(get_offset)
        local offset_param=""
        if (( offset > 0 )); then
            offset_param="\"offset\": $((offset + 1)),"
        fi

        local updates
        updates=$(curl -s -m 5 "${API}/getUpdates" \
            -H "Content-Type: application/json" \
            -d "{${offset_param} \"timeout\": ${POLL_INTERVAL}}") || true

        if [[ -z "$updates" ]]; then
            continue
        fi

        local ok
        ok=$(echo "$updates" | jq -r '.ok' 2>/dev/null) || true
        if [[ "$ok" != "true" ]]; then
            # Check for rate limit
            local error_code
            error_code=$(echo "$updates" | jq -r '.error_code' 2>/dev/null) || true
            if [[ "$error_code" == "429" ]]; then
                local retry_after
                retry_after=$(echo "$updates" | jq -r '.parameters.retry_after // 5' 2>/dev/null) || true
                log "Rate limited on getUpdates, sleeping ${retry_after}s"
                sleep "$retry_after"
            fi
            continue
        fi

        local result_count
        result_count=$(echo "$updates" | jq '.result | length' 2>/dev/null) || true
        if [[ "$result_count" == "0" || -z "$result_count" ]]; then
            continue
        fi

        # Process each update
        local i=0
        while (( i < result_count )); do
            local update
            update=$(echo "$updates" | jq ".result[$i]")
            local update_id
            update_id=$(echo "$update" | jq -r '.update_id')

            # Update offset
            set_offset "$update_id"

            # Extract message
            local message
            message=$(echo "$update" | jq '.message // empty')
            if [[ -z "$message" || "$message" == "null" ]]; then
                (( i++ )) || true
                continue
            fi

            # Security: only process messages from allowed user
            local from_id
            from_id=$(echo "$message" | jq -r '.from.id // empty')
            if [[ "$from_id" != "$ALLOWED_USER" ]]; then
                (( i++ )) || true
                continue
            fi

            # Get topic ID
            local topic_id
            topic_id=$(echo "$message" | jq -r '.message_thread_id // 0')

            # Check for file/voice/photo/video/audio BEFORE text processing
            local has_file=false
            if echo "$message" | jq -e '.voice // .document // .photo // .video // .audio' >/dev/null 2>&1; then
                has_file=true
                if (( topic_id > 0 )); then
                    handle_file_message "$message" "$topic_id" || true
                else
                    send_general_message "<i>Send files in a session topic, not the general chat</i>"
                fi
            fi

            # Get text (could be a caption on a file, or a regular message)
            local text
            text=$(echo "$message" | jq -r '.text // .caption // empty')

            if [[ -z "$text" ]]; then
                (( i++ )) || true
                continue
            fi

            log "Message from topic $topic_id: ${text:0:80}"

            # Check for commands
            case "$text" in
                /sessions|/sessions@*)
                    cmd_sessions "$topic_id"
                    ;;
                /new*)
                    local mode="normal"
                    if [[ "$text" =~ /new[[:space:]]+(danger|normal) ]]; then
                        mode="${BASH_REMATCH[1]}"
                    fi
                    cmd_new "$topic_id" "$mode"
                    ;;
                /resume|/resume@*)
                    cmd_resume "$topic_id"
                    ;;
                /kill*)
                    local target=""
                    if [[ "$text" =~ /kill[[:space:]]+([0-9]+) ]]; then
                        target="${BASH_REMATCH[1]}"
                    fi
                    cmd_kill "$topic_id" "$target"
                    ;;
                /approval*)
                    local answer=""
                    if [[ "$text" =~ /approval[[:space:]]+(.*) ]]; then
                        answer="${BASH_REMATCH[1]}"
                        # Normalize: strip whitespace and lowercase
                        answer=$(echo "$answer" | tr -d '[:space:]' | tr '[:upper:]' '[:lower:]')
                    fi
                    cmd_approval "$topic_id" "$answer"
                    ;;
                /status|/status@*)
                    cmd_status "$topic_id"
                    ;;
                /cancel|/cancel@*)
                    cmd_cancel "$topic_id"
                    ;;
                /restart|/restart@*)
                    cmd_restart "$topic_id"
                    ;;
                /close|/close@*)
                    cmd_close "$topic_id"
                    ;;
                /screenshot|/screenshot@*)
                    cmd_screenshot "$topic_id"
                    ;;
                /help|/help@*|/start|/start@*)
                    cmd_help "$topic_id"
                    ;;
                *)
                    # If this text came with a file, don't also route it as a message
                    if [[ "$has_file" == "true" ]]; then
                        :
                    # Check if this is a resume reply
                    elif handle_resume_reply "$topic_id" "$text" 2>/dev/null; then
                        :
                    elif (( topic_id > 0 )); then
                        # Route to session
                        route_message "$topic_id" "$text"
                    fi
                    ;;
            esac

            (( i++ )) || true
        done
    done
}

main_loop
