        mark_topic_inactive "$session_name"
        return
    fi

    local pane_output
    pane_output=$(tmux capture-pane -t "${session_name}:1.1" -p -S -50 2>/dev/null) || true

    if [[ -z "$pane_output" ]]; then
        send_message "$topic_id" "<i>Empty screen</i>"
        return
    fi

    local escaped_output
    escaped_output=$(escape_html "$pane_output")

    local msg="<pre>${escaped_output}</pre>"
    if (( ${#msg} > 4096 )); then
        # Truncate to last 50 lines and re-escape
        pane_output=$(echo "$pane_output" | tail -50)
        escaped_output=$(escape_html "$pane_output")
        msg="<i>(truncated)</i>
<pre>${escaped_output}</pre>"
        # If still too long, hard-truncate
        if (( ${#msg} > 4096 )); then
            msg="${msg:0:4080}...</pre>"
        fi
    fi

    send_message "$topic_id" "$msg"
}

